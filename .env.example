# Copy to .env.local and fill in values. Never commit .env.local.

# ─── Gemini (required for real AI meal analysis) ─────────────────────────────
# Get from https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase (optional — template auth only; meals are NOT stored here) ─────
EXPO_PUBLIC_SUPABASE_URL=https://example.com
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=dummy

# ─── Optional template services ──────────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Skip Expo dependency API check on restricted networks (optional)
EXPO_NO_DEPENDENCY_VALIDATION=1
